{
  "name": "@sesame/frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Sesame-IDAM frontend workspace (ADR-010): brochure, platform console, tenant console, hosted auth surface, client SDK.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter './*' build",
    "typecheck": "pnpm -r --filter './*' typecheck",
    "dev:auth": "pnpm --filter @sesame/auth dev",
    "dev:platform": "pnpm --filter @sesame/platform dev",
    "dev:tenant": "pnpm --filter @sesame/tenant dev",
    "dev:brochure": "pnpm --filter @sesame/brochure dev"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-solid": "^2.10.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}
