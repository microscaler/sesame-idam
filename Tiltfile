local_resource(
    'sesame-idam-idam-all-gens' % pname,
    "echo \"sesame-idam All idam codegen complete\"" % pname,
    resource_deps=['%s-service-gen' % name for name in DISCOVERED_IDAM_SERVICES],
    labels=['sesame-idam_all_gens']
    allow_parallel=False,
)

for name in DISCOVERED_IDAM_SERVICES:
    service_spec_file = 'idam/%s' % IDAM_SPEC_PATHS.get(name, '%s/openapi.yaml' % name)
    create_microservice_lint(name, service_spec_file)
    create_microservice_gen(name, service_spec_file, name)
    create_microservice_build_resource(name)
    create_microservice_deployment(name)

